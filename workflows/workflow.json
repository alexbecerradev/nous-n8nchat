      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"reply\": {\n      \"type\": \"string\",\n      \"description\": \"Message for the user\"\n    },\n    \"interest_level\": {\n      \"type\": \"string\",\n      \"enum\": [\"LOW\", \"MEDIUM\", \"HIGH\"],\n      \"description\": \"User's interest level: LOW (general questions), MEDIUM (interested but not ready), HIGH (wants automation or pricing)\"\n    },\n    \"name\": {\n      \"type\": \"string\",\n      \"description\": \"User's name (only if interest is HIGH and provided)\"\n    },\n    \"business\": {\n      \"type\": \"string\",\n      \"description\": \"Business name (only if interest is HIGH and provided)\"\n    },\n    \"phone\": {\n      \"type\": \"string\",\n      \"description\": \"Phone or WhatsApp number (only if interest is HIGH and provided)\"\n    },\n    \"email\": {\n      \"type\": \"string\",\n      \"description\": \"Email address (only if interest is HIGH and provided)\"\n    },\n    \"need\": {\n      \"type\": \"string\",\n      \"description\": \"What they want to automate (only if interest is HIGH and provided)\"\n    }\n  },\n  \"required\": [\"reply\", \"interest_level\", \"name\", \"business\", \"phone\", \"email\", \"need\"]\n}"
